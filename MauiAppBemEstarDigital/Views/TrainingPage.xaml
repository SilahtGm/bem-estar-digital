<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppBemEstarDigital.Views.TrainingPage"
             Title="Treinos"
             BackgroundColor="#F4F6F8">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Voltar"
         Priority="0"
         Order="Primary"
         Clicked="Voltar_Clicked"/>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

           
            <Label Text="💪 Treinos e Exercícios"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#1E1E1E"/>

            <Label Text="Escolha o treino ideal para o seu momento e cuide do seu corpo."
                   FontSize="15"
                   Opacity="0.7"
                   TextColor="#000"/>

            <!-- CARD PRINCIPAL -->
            <Border StrokeThickness="0"
                    BackgroundColor="#FFF3E0"
                    StrokeShape="RoundRectangle 30"
                    Padding="22">

                <Border.Shadow>
                    <Shadow Brush="#20000000"
                            Offset="0,6"
                            Radius="16"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="24">

                    <Label Text="Escolha seu tipo de treino"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#E65100"/>

                    <!-- PICKER -->
                    <Picker x:Name="pickerTreinos"
                            Title="Selecione um treino"
                            BackgroundColor="White"
                            TextColor="#333"
                            HeightRequest="60">
                        <Picker.Items>
                            <x:String>Emagrecimento</x:String>
                            <x:String>Ganho de Massa</x:String>
                            <x:String>Treino em Casa</x:String>
                            <x:String>Cardio</x:String>
                            <x:String>Alongamento</x:String>
                            <x:String>Funcional</x:String>
                        </Picker.Items>
                    </Picker>



                    <Button Text="Iniciar treino"
                            BackgroundColor="#FB8C00"
                            TextColor="White"
                            CornerRadius="20"
                            HeightRequest="50"
                            FontAttributes="Bold"
                           />

                </VerticalStackLayout>
            </Border>

            <!-- IMAGEM -->
            <Border StrokeShape="RoundRectangle 25"
                    Padding="0"
                    HeightRequest="180">

                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,6"
                            Radius="16"/>
                </Border.Shadow>

                <Image Source="academia2.jpg"
                       Aspect="AspectFill"/>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>