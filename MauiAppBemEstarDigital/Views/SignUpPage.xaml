<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppBemEstarDigital.Views.SignUpPage"
             Title="Criar Conta"
             BackgroundColor="#f0f4f7">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <!-- Título -->
            <Label Text="Crie sua conta" 
                   FontSize="32" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2c3e50"/>

            <Label Text="Preencha os campos abaixo para se registrar" 
                   FontSize="16" 
                   HorizontalOptions="Center"
                   TextColor="#7f8c8d"/>

            <!-- Campo Email -->
            <Entry Placeholder="Email"
                   Keyboard="Email"
                   TextColor="#2c3e50"
                   BackgroundColor="White"
                   HeightRequest="50"
                  
                   />

            <!-- Campo Senha -->
            <Entry Placeholder="Senha"
                   IsPassword="True"
                   TextColor="#2c3e50"
                   BackgroundColor="White"
                   HeightRequest="50"
                  
                   />

            <!-- Confirmar Senha -->
            <Entry Placeholder="Confirmar Senha"
                   IsPassword="True"
                   TextColor="#2c3e50"
                   BackgroundColor="White"
                   HeightRequest="50"
                   />

            <!-- Botão Registrar -->
            <Button Text="Registrar"
                    BackgroundColor="#3498db"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    />

            <!-- Voltar para Login -->
            <HorizontalStackLayout HorizontalOptions="Center">
                <Label Text="Já tem uma conta?" TextColor="#7f8c8d"/>
                <Button Text="Login" 
                        Clicked="Login_Clicked"
                        BackgroundColor="Transparent"
                        TextColor="#3498db"
                        FontAttributes="Bold"
                        />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>